{
	"name": "restart-vscode-server",
	"displayName": "%extension.displayName%",
	"version": "0.0.3",
	"description": "%extension.description%",
	"categories": [
		"Other",
		"Programming Languages"
	],
	"bugs": {
		"url": "https://github.com/mulingyuer/restart-vscode-server/issues"
	},
	"license": "SEE LICENSE IN LICENSE",
	"repository": {
		"type": "git",
		"url": "https://github.com/mulingyuer/restart-vscode-server"
	},
	"publisher": "mulingyuer",
	"main": "./dist/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@types/vscode": "^1.75.0",
		"@typescript-eslint/eslint-plugin": "^8.31.1",
		"@typescript-eslint/parser": "^8.31.1",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^9.25.1",
		"oxfmt": "^0.42.0",
		"ts-loader": "^9.5.4",
		"typescript": "^6.0.2",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2"
	},
	"l10n": "./l10n",
	"contributes": {
		"commands": [
			{
				"command": "restart-vscode-server.restartTsServer",
				"title": "%command.restartTsServer.title%"
			},
			{
				"command": "restart-vscode-server.restartESLintService",
				"title": "%command.restartESLintService.title%"
			},
			{
				"command": "restart-vscode-server.restartVueService",
				"title": "%command.restartVueService.title%"
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"restart-vscode-server.showRestartTsServerStatusButton": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.showRestartTsServerStatusButton.description%"
				},
				"restart-vscode-server.showRestartESLintButton": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.showRestartESLintButton.description%"
				},
				"restart-vscode-server.showRestartVueButton": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.showRestartVueButton.description%"
				}
			}
		}
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"icon": "public/icon.png",
	"galleryBanner": {
		"color": "#004284",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.75.0"
	}
}
